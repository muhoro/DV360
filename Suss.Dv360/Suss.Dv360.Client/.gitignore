# This is a reusable class library. It should not contain credentials or
# local runtime artifacts. This file exists as a safeguard in case
# developers accidentally drop credential files here during development.
# =============================================================================

# ----- Google credentials -----
# Guard against accidentally dropping key files into the library project.
service-account-key.json
client_secret*.json
*.p12

# ----- Generated documentation -----
# XML doc output from <GenerateDocumentationFile> if enabled.
*.xml
!*.csproj
